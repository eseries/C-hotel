generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum Role {
  SUPER_ADMIN
  OWNER
  MANAGER
  RECEPTIONIST
  HOUSEKEEPING
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  DIRTY
  MAINTENANCE
  CLEANING
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  firstName     String
  lastName      String
  phone         String?
  role          Role           @default(RECEPTIONIST)
  isActive      Boolean        @default(true)
  hotelId       String?
  hotel         Hotel?         @relation(fields: [hotelId], references: [id])
  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([hotelId])
}

model Hotel {
  id                String             @id @default(cuid())
  name              String
  slug              String             @unique
  email             String?
  phone             String?
  address           String?
  city              String?
  country           String?
  currency          String             @default("NGN")
  timezone          String             @default("UTC")
  checkInTime       String             @default("14:00")
  checkOutTime      String             @default("12:00")
  taxRate           Float              @default(0)
  users             User[]
  roomTypes         RoomType[]
  rooms             Room[]
  guests            Guest[]
  reservations      Reservation[]
  payments          Payment[]
  housekeepingTasks HousekeepingTask[]
  dailyReports      DailyReport[]
  stayHistory       GuestStayHistory[]
  subscriptions     Subscription[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([name])
}

model RoomType {
  id          String   @id @default(cuid())
  hotelId     String
  hotel       Hotel    @relation(fields: [hotelId], references: [id])
  name        String
  description String?
  basePrice   Float
  capacity    Int      @default(1)
  amenities   String
  rooms       Room[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([hotelId, name])
  @@index([hotelId])
}

model Room {
  id           String             @id @default(cuid())
  hotelId      String
  hotel        Hotel              @relation(fields: [hotelId], references: [id])
  roomTypeId   String
  roomType     RoomType           @relation(fields: [roomTypeId], references: [id])
  roomNumber   String
  floor        Int?
  status       RoomStatus         @default(AVAILABLE)
  customPrice  Float?
  notes        String?
  reservations Reservation[]
  housekeeping HousekeepingTask[]
  stayHistory  GuestStayHistory[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([hotelId, roomNumber])
  @@index([hotelId])
  @@index([status])
}

model Guest {
  id               String             @id @default(cuid())
  hotelId          String
  hotel            Hotel              @relation(fields: [hotelId], references: [id])
  firstName        String
  lastName         String
  email            String?
  phone            String?
  address          String?
  nationality      String?
  identificationNo String?
  dateOfBirth      DateTime?
  reservations     Reservation[]
  stayHistory      GuestStayHistory[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([hotelId])
  @@index([email])
}

model Reservation {
  id            String            @id @default(cuid())
  hotelId       String
  hotel         Hotel             @relation(fields: [hotelId], references: [id])
  guestId       String
  guest         Guest             @relation(fields: [guestId], references: [id])
  roomId        String
  room          Room              @relation(fields: [roomId], references: [id])
  checkInDate   DateTime
  checkOutDate  DateTime
  adults        Int               @default(1)
  children      Int               @default(0)
  status        ReservationStatus @default(PENDING)
  totalAmount   Float
  paidAmount    Float             @default(0)
  paymentStatus PaymentStatus     @default(PENDING)
  source        String?
  notes         String?
  payments      Payment[]
  stayHistory   GuestStayHistory?
  createdById   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([hotelId])
  @@index([guestId])
  @@index([roomId])
  @@index([status])
}

model Payment {
  id            String       @id @default(cuid())
  hotelId       String
  hotel         Hotel        @relation(fields: [hotelId], references: [id])
  reservationId String?
  reservation   Reservation? @relation(fields: [reservationId], references: [id])
  amount        Float
  method        String
  reference     String?
  paidAt        DateTime     @default(now())
  createdAt     DateTime     @default(now())

  @@index([hotelId])
  @@index([reservationId])
}

model HousekeepingTask {
  id           String    @id @default(cuid())
  hotelId      String
  hotel        Hotel     @relation(fields: [hotelId], references: [id])
  roomId       String
  room         Room      @relation(fields: [roomId], references: [id])
  assignedToId String?
  taskType     String
  status       String    @default("PENDING")
  priority     String    @default("MEDIUM")
  notes        String?
  dueDate      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([hotelId])
  @@index([roomId])
}

model Subscription {
  id           String    @id @default(cuid())
  hotelId      String
  hotel        Hotel     @relation(fields: [hotelId], references: [id])
  userId       String?
  user         User?     @relation(fields: [userId], references: [id])
  planName     String
  status       String
  startDate    DateTime
  endDate      DateTime?
  amount       Float
  billingCycle String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([hotelId])
  @@index([userId])
}

model DailyReport {
  id             String   @id @default(cuid())
  hotelId        String
  hotel          Hotel    @relation(fields: [hotelId], references: [id])
  reportDate     DateTime
  occupancyRate  Float    @default(0)
  totalBookings  Int      @default(0)
  totalRevenue   Float    @default(0)
  checkInsToday  Int      @default(0)
  checkOutsToday Int      @default(0)
  roomsOccupied  Int      @default(0)
  roomsAvailable Int      @default(0)
  roomsCleaned   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([hotelId, reportDate])
  @@index([hotelId])
}

model GuestStayHistory {
  id            String      @id @default(cuid())
  hotelId       String
  hotel         Hotel       @relation(fields: [hotelId], references: [id])
  guestId       String
  guest         Guest       @relation(fields: [guestId], references: [id])
  roomId        String
  room          Room        @relation(fields: [roomId], references: [id])
  reservationId String      @unique
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  checkInDate   DateTime
  checkOutDate  DateTime
  amountPaid    Float       @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([hotelId])
  @@index([guestId])
  @@index([roomId])
}
